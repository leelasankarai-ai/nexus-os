# Nexus OS Environment Variables

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_FEE=0.05

# Razorpay (get these from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
RAZORPAY_WEBHOOK_SECRET=

# Admin API key for partner management
NEXUS_ADMIN_KEY=

# Wallet fees
NEXT_PUBLIC_WITHDRAWAL_FEE=0.02
